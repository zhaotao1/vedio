# Example scene config for long-video-native.
# Copy & edit, then run:
#   ltxv-long-video --config scene.yaml

model:
  checkpoint_path: ~/models/ltxv2/ltx-2.3-22b-dev.safetensors
  distilled_lora_path: ~/models/ltxv2/distilled-lora.safetensors
  spatial_upsampler_path: ~/models/ltxv2/upsampler.safetensors
  gemma_root: ~/models/gemma-3
  # loras: [["~/models/character_lora.safetensors", 0.8]]
  loras: []
  quantization: null              # null | fp8-cast | fp8-scaled-mm
  offload: none                   # none | cpu | disk
  compile: false

pipeline:
  mode: two_stages_hq             # two_stages | two_stages_hq

common:
  height: 704                     # must be divisible by 64 (two-stage)
  width: 1216                     # must be divisible by 64
  frame_rate: 24.0
  seed: 42
  output_path: ./out/long_demo.mp4
  enhance_prompt: false

looping:
  chunk_num_frames: 121           # 8K+1 (24 fps × ≈5 s per segment)
  overlap_latent_frames: 3        # = 24 pixel frames overlap
  overlap_strength: 0.5           # ComfyUI temporal_overlap_cond_strength
  enable_negative_index: true     # long-term memory anchor
  negative_index_anchor_latent_frames: 2
  negative_index_strength: 0.3
  negative_frame_offset: -16      # pixel frames; must be < 0
  adain_factor: 0.5               # 0 disables, 1 fully matches first segment

# Optional guidance overrides.
guidance:
  num_inference_steps: 30          # two_stages default 30; HQ default 15
  max_batch_size: 1
  # negative_prompt: "blurry, low quality, artifacts"
  # video:
  #   cfg_scale: 3.0
  #   stg_scale: 1.0
  #   rescale_scale: 0.7
  #   modality_scale: 3.0
  #   skip_step: 0
  #   stg_blocks: [28]
  # audio:
  #   cfg_scale: 7.0
  #   stg_scale: 1.0
  #   rescale_scale: 0.7
  #   modality_scale: 3.0
  #   skip_step: 0
  #   stg_blocks: [28]

# Omit `spatial_tiling:` block entirely for single-tile generation.
# Enable below for high-resolution (e.g. 1408×2432) renders.
# spatial_tiling:
#   tile_height_px: 704
#   tile_width_px: 1216
#   spatial_overlap_px: 128       # must be a multiple of 32 (VAE scale)

prompts:
  - "A woman walks into a neon-lit cafe at night, slow tracking shot"
  - "She sits at the bar; the bartender pours hot coffee into a ceramic cup"
  - "She takes a slow sip, steam rising; soft amber rim light"
  - "She looks out the rainy window, thoughtful; reflections shimmer"

# Optional, aligned with `prompts`:
# keyframes_per_segment:
#   - []
#   - [["./refs/anchor_seg1.png", 0, 0.9]]
#   - []
#   - []

# ---------------------------------------------------------------------------
# ComfyUI LTXVLoopingSampler-aligned options (all OPT-IN; defaults preserve
# the legacy behaviour above so old configs run unchanged).
# ---------------------------------------------------------------------------

# Global keyframes (pixel-frame index across the full timeline); the runner
# routes each one to the matching temporal tile via core/keyframe_router.
# cond_images:
#   - {path: "./refs/anchor_start.png",  frame_idx: 0,   strength: 0.9}
#   - {path: "./refs/anchor_middle.png", frame_idx: 240, strength: 0.7}

# Sampler / seeding controls — mirrors ComfyUI ``LTXVLoopingSampler``.
# sampler:
#   share_prompt_encoding: true       # P3: shared PromptContextCache
#   use_extend_sampler: true          # P4: clean-prefix overlap (VideoConditionByLatentIndex)
#   seeding_mode: comfyui             # 'comfyui' | 'per_segment_legacy'
#   per_tile_seed_offsets: [0, 1, 2]  # repeats the last value as needed
#   cond_image_strength: 1.0
#   guiding_strength: 1.0             # P8 (placeholder; IC-LoRA not wired yet)
#   guiding_start_step: 0
#   guiding_end_step: 1000

# Recommended new home for negative-index settings (looping: keys above
# remain accepted for backward compatibility).
# negative_index:
#   enabled: true
#   anchor_latent_frames: 2
#   strength: 0.3
#   frame_offset: -16
#   external_latents_path: ./refs/neg_anchor.pt  # P5: override captured anchor

# P6 — DynamicConditioning: raise denoise_mask to ``power`` each step.
# dynamic_conditioning:
#   enabled: true
#   power: 1.3
#   only_first_frame: true

# P5 — external reference latents.
# references:
#   normalizing_latents_path: ./refs/colour_ref.pt    # AdaIN reference
#   guiding_latents_path: ./refs/guide.pt             # P8 placeholder
